-- Store original part sizes for scale restore
State.OrigPartSizes = nil

local function setCharScale(s)
    if not Char then return end

    -- On first scale: cache every part's original Size
    if not State.OrigPartSizes then
        State.OrigPartSizes = {}
        for _, v in pairs(Char:GetDescendants()) do
            if v:IsA("BasePart") then
                State.OrigPartSizes[v] = v.Size
            end
        end
    end

    for _, v in pairs(Char:GetDescendants()) do
        if v:IsA("BasePart") then
            local orig = State.OrigPartSizes[v]
            if orig then
                v.Size = orig * s
            end
        end
    end

    -- Also scale motor offsets so parts don't separate/clip
    if Humanoid then
        for _, v in pairs(Char:GetDescendants()) do
            if v:IsA("Motor6D") then
                -- Roblox default Motor6D C0/C1 offsets need scaling too
                pcall(function()
                    v.C0 = v.C0 * CFrame.new(0, 0, 0)  -- joints auto-adjust with part sizes
                end)
            end
        end
    end
end

local function resetCharScale()
    if not Char or not State.OrigPartSizes then return end
    for _, v in pairs(Char:GetDescendants()) do
        if v:IsA("BasePart") then
            local orig = State.OrigPartSizes[v]
            if orig then v.Size = orig end
        end
    end
    State.OrigPartSizes = nil
end

