        if v:IsA("TextButton") or v:IsA("TextLabel") then v:Destroy() end
    end
end
local function doSearch(q)
    clearSearch()
    if q == "" then
        SearchPage.Visible = false
        for k, pg in pairs(Pages) do pg.Visible = k == currentTab end
        return
    end
    for k, pg in pairs(Pages) do pg.Visible = false end
    SearchPage.Visible = true
    q = q:lower()
    local n = 0
    for _, h in ipairs(allHacks) do
        if h.label:lower():find(q, 1, true) then
            local proxy = Instance.new("TextButton")
            proxy.Size             = UDim2.new(1, 0, 0, toggleH)
