    currentTab = key
    for k, btn in pairs(TabBtns) do
        tw(btn, {
            BackgroundColor3 = k == key and Color3.fromRGB(110,40,210) or Color3.fromRGB(20,15,40),
            TextColor3       = k == key and Color3.fromRGB(255,255,255) or Color3.fromRGB(120,90,170),
        }, 0.15)
    end
    for k, pg in pairs(Pages) do pg.Visible = k == key end
    if SearchPage then SearchPage.Visible = false end
    if SearchBar  then SearchBar.Text = "" end
end

