local function mkSlider(page, label, minV, maxV, default, callback)
    local sliderH = isMobile and 68 or 58
    local frame = Instance.new("Frame")
    frame.Size             = UDim2.new(1, 0, 0, sliderH)
    frame.BackgroundColor3 = Color3.fromRGB(15, 11, 30)
    frame.BorderSizePixel  = 0
    frame.ZIndex           = 102
    frame.Parent           = page
    mkCorner(frame, 10)
    mkStroke(frame, Color3.fromRGB(50, 35, 90), 1, 0.6)

    local lbl = newLabel(frame, label, Enum.Font.Gotham,
        isMobile and 14 or 13, Color3.fromRGB(200,175,230), 103)
    lbl.Size = UDim2.new(1, -60, 0, 20)
    lbl.Position = UDim2.new(0, 12, 0, 8)
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local valLbl = newLabel(frame, tostring(default), Enum.Font.GothamBold,
        isMobile and 14 or 13, Color3.fromRGB(160,120,255), 103)
    valLbl.Size = UDim2.new(0, 50, 0, 20)
    valLbl.Position = UDim2.new(1, -58, 0, 8)
    valLbl.TextXAlignment = Enum.TextXAlignment.Right

    local trackH = isMobile and 8 or 6
    local track = Instance.new("Frame")
    track.Size             = UDim2.new(1, -24, 0, trackH)
    track.Position         = UDim2.new(0, 12, 0, sliderH - trackH - 12)
    track.BackgroundColor3 = Color3.fromRGB(35, 25, 65)
    track.BorderSizePixel  = 0
    track.ZIndex           = 103
    track.Parent           = frame
    mkCorner(track, trackH/2)

    local fill = Instance.new("Frame")
    fill.Size             = UDim2.new((default-minV)/(maxV-minV), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(110, 40, 220)
    fill.BorderSizePixel  = 0
    fill.ZIndex           = 104
    fill.Parent           = track
    mkCorner(fill, trackH/2)

    local knobSz = isMobile and 18 or 14
    local knob = Instance.new("Frame")
    knob.Size             = UDim2.new(0, knobSz, 0, knobSz)
    knob.AnchorPoint      = Vector2.new(0.5, 0.5)
    knob.Position         = UDim2.new((default-minV)/(maxV-minV), 0, 0.5, 0)
    knob.BackgroundColor3 = Color3.fromRGB(160, 90, 255)
    knob.BorderSizePixel  = 0
    knob.ZIndex           = 105
    knob.Parent           = track
    mkCorner(knob, knobSz/2)

    local dragging = false
    local function update(x)
        local rel = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local val = math.floor(minV + (maxV - minV) * rel)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, 0, 0.5, 0)
        valLbl.Text = tostring(val)
        pcall(callback, val)
    end
    track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = true; update(inp.Position.X)
        end
    end)
    UIS.InputChanged:Connect(function(inp)
        if dragging and (inp.UserInputType == Enum.UserInputType.MouseMovement
        or inp.UserInputType == Enum.UserInputType.Touch) then
            update(inp.Position.X)
        end
    end)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    pcall(callback, default)
    return frame
end

