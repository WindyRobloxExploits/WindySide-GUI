    if on and RootPart then
        local bv = Instance.new("BodyVelocity")
        bv.Name = "WS_HoverBV"; bv.MaxForce = Vector3.new(1e5,3e4,1e5); bv.Parent = RootPart
        local bg = Instance.new("BodyGyro")
        bg.Name = "WS_HoverBG"; bg.MaxTorque = Vector3.new(0,4e5,0); bg.P = 1e4; bg.Parent = RootPart
