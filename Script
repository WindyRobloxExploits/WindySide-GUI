mkToggle(MiscP, "Anti-Cheat Bypass Attempt (Spoof velocity reads)", function(on)
    if Connections.ACBypass then Connections.ACBypass:Disconnect() end
    if on and RootPart then
        local mt = getrawmetatable and getrawmetatable(RootPart)
        if mt then
            pcall(function()
                setreadonly(mt, false)
                local realIndex = mt.__index
                mt.__index = function(t, k)
                    if k == "Velocity" or k == "AssemblyLinearVelocity" then
                        local real = realIndex(t, k)
                        if real.Magnitude > 100 then
                            return Vector3.new(real.X*0.1, real.Y*0.1, real.Z*0.1)
                        end
                        return real
                    end
                    return realIndex(t, k)
                end
                setreadonly(mt, true)
            end)
        end
    end
end)

