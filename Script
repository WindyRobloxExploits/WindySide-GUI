mkSection(CP, "🍆  Bang")
mkToggle(CP, "Bang (Goes Behind Target) 💦", function(on)
    -- Cleanup
    if Connections.Bang then Connections.Bang:Disconnect(); Connections.Bang = nil end
    if Connections.BangDied then Connections.BangDied:Disconnect(); Connections.BangDied = nil end
    if State.BangAnimTrack then
        pcall(function() State.BangAnimTrack:Stop() end)
        pcall(function() State.BangAnimTrack:Destroy() end)
        State.BangAnimTrack = nil
    end
    if State.BangAnimObj then
        pcall(function() State.BangAnimObj:Destroy() end)
        State.BangAnimObj = nil
    end
    if not on then return end
    if not Char or not RootPart or not Humanoid then return end

    -- Helper: get torso/root of a character (R6 + R15 compatible)
    local function getBangTorso(character)
        return character:FindFirstChild("Torso")
            or character:FindFirstChild("UpperTorso")
            or character:FindFirstChild("HumanoidRootPart")
    end

    -- Detect R15 by checking for UpperTorso
    local isR15 = Char:FindFirstChild("UpperTorso") ~= nil

    -- Use correct animation for rig type (R6 vs R15) — matching reference script IDs
    local bangAnim = Instance.new("Animation")
    bangAnim.AnimationId = isR15 and "rbxassetid://5918726674" or "rbxassetid://148840371"
    State.BangAnimObj = bangAnim

    local track = nil
    pcall(function()
        local animator = Humanoid:FindFirstChildOfClass("Animator") or Humanoid
        track = animator:LoadAnimation(bangAnim)
    end)

    if track then
        State.BangAnimTrack = track
        track.Looped = true
        track:Play(0.1, 1, 1)
        track:AdjustSpeed(State.BangSpeed or 3)
    end

    -- Stop animation when character dies (matches reference)
    Connections.BangDied = Humanoid.Died:Connect(function()
        if State.BangAnimTrack then
            pcall(function() State.BangAnimTrack:Stop() end)
            pcall(function() State.BangAnimTrack:Destroy() end)
            State.BangAnimTrack = nil
        end
        if State.BangAnimObj then
            pcall(function() State.BangAnimObj:Destroy() end)
            State.BangAnimObj = nil
        end
        if Connections.Bang then Connections.Bang:Disconnect(); Connections.Bang = nil end
        if Connections.BangDied then Connections.BangDied:Disconnect(); Connections.BangDied = nil end
    end)

    -- CFrame offset — 1.1 studs behind target, same as reference
    local bangOffset = CFrame.new(0, 0, 1.1)

    -- Find the target once and lock onto them
    -- Uses Stepped (same as reference) for smooth physics-synced positioning
    Connections.Bang = RunService.Stepped:Connect(function()
        if not RootPart or not Char then return end

        -- Find closest player
        local closestPlayer = nil
        local closestDist = math.huge
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LP and p.Character then
                local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local d = (hrp.Position - RootPart.Position).Magnitude
                    if d < closestDist then
                        closestDist = d
                        closestPlayer = p
                    end
                end
            end
        end

        if closestPlayer and closestPlayer.Character then
            local otherRoot = getBangTorso(closestPlayer.Character)
            if otherRoot then
                -- Lock our root behind their root, offset forward — matches reference logic
                pcall(function()
                    RootPart.CFrame = otherRoot.CFrame * bangOffset
                end)
            end
        end

        -- Keep animation speed live from slider
        if State.BangAnimTrack and State.BangAnimTrack.IsPlaying then
            pcall(function()
                State.BangAnimTrack:AdjustSpeed(State.BangSpeed or 3)
            end)
        end
    end)
end)
