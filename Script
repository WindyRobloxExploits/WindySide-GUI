            if not msgActive then break end
            msgIndex = (msgIndex % #orbMessages) + 1
            -- Fade out
            for i = 1, 5 do
                msgLabel.TextTransparency = i * 0.2
                task.wait(0.04)
            end
            msgLabel.Text = orbMessages[msgIndex]
            -- Pulse the glow colour to match message change
            local glowColors = {
                Color3.fromRGB(140, 0, 255),
                Color3.fromRGB(80, 0, 200),
                Color3.fromRGB(180, 0, 255),
                Color3.fromRGB(60, 0, 160),
            }
            local c = glowColors[((msgIndex - 1) % #glowColors) + 1]
            core.Color = c
            light.Color = c
            -- Fade back in
            for i = 1, 5 do
                msgLabel.TextTransparency = 1 - i * 0.2
                task.wait(0.04)
            end
            msgLabel.TextTransparency = 0
        end
    end)

