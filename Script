mkToggle(CP, "Gravity Gun (Pull nearest to you)", function(on)
    if Connections.GravGun then Connections.GravGun:Disconnect() end
    -- Remove visual beam on disable
    local beam = ScreenGui:FindFirstChild("WS_GravBeam")
    if beam then beam:Destroy() end
    if not on then return end
    -- Visual beam label
    local beamLbl = Instance.new("TextLabel")
    beamLbl.Name = "WS_GravBeam"
    beamLbl.Size = UDim2.new(0,0,0,0)
    beamLbl.BackgroundTransparency = 1
    beamLbl.Text = ""
    beamLbl.ZIndex = 1
    beamLbl.Parent = ScreenGui
    Connections.GravGun = RunService.Heartbeat:Connect(function()
        if not RootPart then return end
        local closest, closestDist = nil, math.huge
        local closestPlayer = nil
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LP and p.Character then
                local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local d = (hrp.Position - RootPart.Position).Magnitude
                    if d < closestDist then
                        closestDist = d
                        closest = hrp
                        closestPlayer = p
                    end
                end
            end
        end
        if closest and closestDist < 80 and closestDist > 2 then
            -- CFrame-pull: move their HRP toward us by a step each frame
            -- This works because we own the physics prediction locally
            local dir = (RootPart.Position - closest.Position).Unit
            local pullSpeed = math.min(4, closestDist * 0.15)
            closest.CFrame = closest.CFrame + dir * pullSpeed
            -- Draw a 2D beam line between us and target on screen
            local sp1, on1 = Camera:WorldToScreenPoint(RootPart.Position)
            local sp2, on2 = Camera:WorldToScreenPoint(closest.Position)
            if on1 and on2 then
                local dx = sp2.X - sp1.X
                local dy = sp2.Y - sp1.Y
                local len = math.sqrt(dx*dx+dy*dy)
                beamLbl.Size = UDim2.new(0, len, 0, 3)
                beamLbl.Position = UDim2.new(0, sp1.X, 0, sp1.Y)
                beamLbl.Rotation = math.deg(math.atan2(dy, dx))
                beamLbl.BackgroundColor3 = Color3.fromRGB(100, 200, 255)
                beamLbl.BackgroundTransparency = 0.3
                beamLbl.BorderSizePixel = 0
            end
        end
    end)
end)

