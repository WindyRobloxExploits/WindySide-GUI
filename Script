        glow.Size  = Vector3.new(p1, p1, p1)
        glow2.Size = Vector3.new(p2, p2, p2)

        -- Core pulses brightness (simulated by size)
        local cp = 0.4 + math.sin(t * 4) * 0.15
        core.Size = Vector3.new(cp, cp, cp)

        -- Light brightness pulses
        light.Brightness = 7 + math.sin(t * 3) * 3

        -- Glow shells shift between deep purples/magentas
        local hue = 0.75 + math.sin(t * 0.2) * 0.06  -- stays in purple band 0.69–0.81
        glow.Color  = Color3.fromHSV(hue, 1, 0.9)
        glow2.Color = Color3.fromHSV(hue - 0.05, 1, 0.6)

        -- Stroke on billboard pulses too
        bgStroke.Transparency = 0.2 + math.sin(t * 3) * 0.3
    end)

    -- Cleanup msgActive when toggled off
    Connections.WindyOrbCleanup = game:GetService("RunService").Heartbeat:Connect(function()
        if not State.WindyOrbPart or not State.WindyOrbPart.Parent then
            msgActive = false
            if Connections.WindyOrbCleanup then Connections.WindyOrbCleanup:Disconnect() end
        end
    end)
end)
